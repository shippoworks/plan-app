{
  "name": "yatta-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "pages:dev": "wrangler pages dev -- npm run dev",
    "db:init:local": "wrangler d1 execute yatta-db --local --file=./schema.sql",
    "db:seed:local": "wrangler d1 execute yatta-db --local --file=./seed.sql",
    "db:init:remote": "wrangler d1 execute yatta-db --remote --file=./schema.sql",
    "db:seed:remote": "wrangler d1 execute yatta-db --remote --file=./seed.sql"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^3.91.0"
  }
}
